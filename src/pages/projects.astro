---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopLayout from '../layouts/TopLayout.astro'
import BottomLayout from '../layouts/BottomLayout.astro'

import { PROJECTS, PROJECTPAGE } from '../lib/constants'
import { Button } from '@/components/ui/button'
import { ChevronLeft, ExternalLink } from 'lucide-react'
---

<BaseLayout title={"Anurag Parida - " + PROJECTPAGE.TITLE} description={PROJECTPAGE.DESCRIPTION}>
  <main class="flex min-h-[80vh] flex-auto flex-col" transition:animate="fade">
    <TopLayout>
      <h2
        class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight first:mt-0"
      >
        <a href="/" class="mr-2 text-primary">
          <Button variant="default" size="icon">
            <ChevronLeft />
          </Button>
        </a>
        {PROJECTPAGE.TITLE}
      </h2>
    </TopLayout>
    <BottomLayout>
      <ul>
        {
          PROJECTS.map((entry) => (
            <li class="animate mt-8 border-b border-black/10 pb-8 first-of-type:mt-0 last-of-type:border-none dark:border-white/25">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <a
                  href={entry.link ?? '#'}
                  class={`text-xl font-semibold ${entry?.link ? 'text-primary' : 'text-foreground'}`}
                >
                  {entry.title}
                </a>
                <span class="text-sm uppercase tracking-wide text-muted-foreground">
                  {entry.date}
                </span>
              </div>

              {entry.outcome && (
                <p class="mt-2 text-sm font-medium text-foreground/90">
                  {entry.outcome}
                </p>
              )}

              {entry.role && (
                <p class="mt-1 text-xs uppercase tracking-wide text-muted-foreground">
                  {entry.role}
                </p>
              )}

              <p class="mt-3 text-sm leading-relaxed">{entry.description}</p>

              {entry.impact && (
                <p class="mt-3 text-sm leading-relaxed text-foreground/80">
                  <span class="font-semibold">Impact: </span>
                  {entry.impact}
                </p>
              )}

              {entry.stack && entry.stack.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {entry.stack.map((tech) => (
                    <span class="rounded-full border border-border bg-muted px-2.5 py-0.5 text-xs text-muted-foreground">
                      {tech}
                    </span>
                  ))}
                </div>
              )}

              {entry.link && (
                <a
                  href={entry.link}
                  target="_blank"
                  rel="noopener"
                  class="mt-3 inline-flex items-center gap-1 text-sm text-primary underline-offset-4 hover:underline"
                >
                  View project <ExternalLink size={14} />
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </BottomLayout>
  </main>
</BaseLayout>
