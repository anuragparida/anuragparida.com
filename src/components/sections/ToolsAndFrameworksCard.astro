---
import Card from '../Card.astro'
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-1" title="Tools & Frameworks">
  <div class="flex flex-col gap-2">
    <p class="pt-1 text-sm font-light">
      <span class="text-xs uppercase tracking-wide text-muted-foreground">Languages</span><br />
      TypeScript, Python, SQL, Bash, Go (learning)
    </p>
    <p class="pt-1 text-sm font-light">
      <span class="text-xs uppercase tracking-wide text-muted-foreground">Cloud &amp; data</span><br />
      Kubernetes, AWS, Docker, Databricks, Kafka, Airflow, Grafana, PowerBI
    </p>
    <p class="pt-1 text-sm font-light">
      <span class="text-xs uppercase tracking-wide text-muted-foreground">ML &amp; AI</span><br />
      PyTorch, Hugging Face, OpenAI, Gemini, LangChain, BERTopic, HDBSCAN, pgvector
    </p>
    <p class="pt-1 text-sm font-light">
      <span class="text-xs uppercase tracking-wide text-muted-foreground">Web &amp; product</span><br />
      React, Next.js, Astro, Tailwind, Node, FastAPI, MERN, React Native, PostgreSQL, MongoDB
    </p>
  </div>
</Card>
