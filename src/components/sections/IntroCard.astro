---
import Card from '../Card.astro'
import { Button } from '../ui/button'
import { LINKS } from '../../lib/constants'
import { Linkedin, Github, Mail } from 'lucide-react'
---

<Card colSpan="md:col-span-3" rowSpan="md:row-span-3">
  <div class="flex h-full w-full">
    <div class="flex flex-col justify-between gap-4">
      <div class="flex h-full flex-col">
        <p class="m-0 font-light">
          <span class="text-xl">
            Hi, I'm <b class="font-bold">Anurag Parida</b> 👋🏽
          </span>
          <p class="text-md pr-4 pt-4">
            Software engineer working where cloud, data, and AI meet real-world
            business processes. Currently building scalable automation and
            AI-driven systems for commercial insurance at
            <a
              href="https://www.hdi.global/"
              target="_blank"
              rel="noopener"
              class="text-primary underline-offset-4 hover:underline">HDI Group</a
            >. Previously: thesis on LLM-based search at Mercedes-Benz; founding
            engineer at Zepto (YC SS21, now a unicorn). Always interested in
            interesting work — applied AI, regulated industries, and platform
            engineering.
          </p>
          <p class="text-sm pr-4 pt-3 text-gray-500">
            The fastest way to reach me is
            <a
              href={LINKS.mail}
              class="text-primary underline-offset-4 hover:underline">email</a
            >
            or
            <a
              href={LINKS.linkedin}
              target="_blank"
              rel="noopener"
              class="text-primary underline-offset-4 hover:underline">LinkedIn</a
            >.
          </p>
        </p>
      </div>
      <div class="flex gap-4">
        <a href={LINKS.github} aria-label="github profile" target="_blank">
          <Button aria-label="github profile">
            <Github />
            <span class="sr-only">GitHub Profile</span>
          </Button>
        </a>
        <a href={LINKS.linkedin} aria-label="linkeding profile" target="_blank">
          <Button aria-label="linkedin profile">
            <Linkedin />
            <span class="sr-only">Linkedin Profile</span>
          </Button>
        </a>
        <a href={LINKS.mail} aria-label="mail profile" target="_blank">
          <Button>
            <Mail />
            <span class="sr-only">Email contact</span>
          </Button>
        </a>
      </div>
    </div>
    <img
      width="300"
      height="300"
      src="/portraitSquare.jpg"
      class="pointer-events-none absolute bottom-[-20px] right-[-110px] z-[-1] max-h-[300px] w-auto select-none rounded-full opacity-50 shadow md:relative md:bottom-auto md:right-auto md:z-auto md:rounded-md md:opacity-100"
      alt="picture of anurag parida"
    />
  </div>
</Card>
